{
  "name": "camp-lawton-leader-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "npm run survey:check",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build && node scripts/prune-deploy-assets.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run survey:check && node --import tsx --test tests/rendered-html.test.mjs tests/preview.test.mjs tests/publication-slice.test.mjs tests/full-product.test.mjs tests/history.test.mjs tests/conditions.test.ts tests/merit-badge-survey.test.ts tests/markdown-content.test.tsx tests/leader-guide-coverage.test.ts tests/release-scope.test.tsx tests/packing-list.test.tsx tests/tribe-of-papago.test.ts",
    "check": "npm run lint && npm run build && npm run test",
    "preview:static": "python -m http.server 8080 --directory preview",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "survey:generate": "node scripts/generate-merit-badge-survey.mjs",
    "survey:check": "node scripts/generate-merit-badge-survey.mjs --check",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply camp-lawton-leader-hub --local",
    "db:migrate:remote": "wrangler d1 migrations apply camp-lawton-leader-hub --remote",
    "preview:worker": "wrangler dev --config dist/server/wrangler.json --port 3000"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "framer-motion": "^12.42.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-zoom-pan-pinch": "^4.0.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "csv-parse": "7.0.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "pngjs": "^7.0.0",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
